# Database
DATABASE_URL=postgresql://ujjwalraj@localhost:5432/compound

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# AI Coach — set ONE provider's API key to enable Coach
# Gemini (default — fast and free up to generous limits)
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Anthropic
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=

# OpenAI
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# OPENAI_API_KEY=

AI_MAX_TOKENS=2048

# App password — when set, the UI and API require login (leave empty for local dev)
APP_PASSWORD=
